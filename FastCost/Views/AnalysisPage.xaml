<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FastCost.Core.Models;assembly=FastCost.Core"
             x:Class="FastCost.Views.AnalysisPage"
             Title="Analysis">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto" Padding="0,0,10,0">
            <Label Grid.Column="0"
                   Text="Analysis"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center" />
            <Button Grid.Column="1"
                    Text="&#x1F4CA; Chart"
                    FontSize="16"
                    FontAttributes="Bold"
                    BackgroundColor="White"
                    TextColor="CadetBlue"
                    CornerRadius="15"
                    HeightRequest="38"
                    Padding="14,0"
                    Clicked="OnChartClicked" />
        </Grid>
    </Shell.TitleView>

    <ContentPage.Resources>
        <DataTemplate x:Key="GroupHeaderTemplate">
            <Label Text="{Binding Key.Name}"  FontSize="16" FontAttributes="Bold" WidthRequest="100" HorizontalTextAlignment="End" HorizontalOptions="Start" />
        </DataTemplate>
        <DataTemplate x:Key="GroupFooterTemplate">
            <Label Text="{Binding Key.SumValue, StringFormat='{0:F2}'}"  FontSize="16" FontAttributes="Bold" TextColor="CadetBlue" Margin="1,0,0,15" WidthRequest="100" HorizontalTextAlignment="End" HorizontalOptions="Start" />
        </DataTemplate>
    </ContentPage.Resources>

    <ContentPage.Content>
        <Grid>
            <Grid.GestureRecognizers>
                <SwipeGestureRecognizer Direction="Right" Swiped="OnSwipedRight"/>
            </Grid.GestureRecognizers>

            <Grid RowDefinitions="Auto,*" Margin="20" RowSpacing="10">

                <DatePicker x:Name="AnalysisPageDatePicker"
                        Grid.Row="0"
                        Date="{Binding SelectedDate}"
                        Format="MM/yyyy"
                        FontSize="20"
                        HorizontalOptions="Center"
                        DateSelected="DatePicker_DateSelected"/>

                <CollectionView x:Name="CollectionViewGroup"
                            Grid.Row="1"
                            ItemsSource="{Binding GroupCosts}"
                            IsGrouped="True"
                            GroupHeaderTemplate="{DynamicResource GroupHeaderTemplate}"
                            GroupFooterTemplate="{DynamicResource GroupFooterTemplate}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Text="{Binding Value, StringFormat='{0:F2}'}" FontSize="16" Margin="1,0,0,0" HorizontalTextAlignment="End" />
                                <Label Grid.Column="1" Text="{Binding Description}" FontSize="16" Margin="1,0,0,0" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.Footer >
                        <Label x:Name = "SumText" Text="{Binding Sum, StringFormat='Total sum: {0:F2}'}" FontSize="16" FontAttributes="Bold" TextColor="CadetBlue" HorizontalTextAlignment="Start" Padding="0, 0"/>
                    </CollectionView.Footer>

                </CollectionView>
            </Grid>
        </Grid>
    </ContentPage.Content>
</ContentPage>