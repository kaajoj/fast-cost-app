<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FastCost.Core.Models;assembly=FastCost.Core"
             x:Class="FastCost.Views.AllCostsPage"
             Title="All Costs">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="" Clicked="Add_Clicked" IconImageSource="{FontImageSource Glyph='+', Size=32, FontFamily=OpenSansRegular, Color={StaticResource White}}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*,Auto" Margin="5">
        <Grid.GestureRecognizers>
            <SwipeGestureRecognizer Direction="Left"  Swiped="OnSwipedLeft"/>
            <SwipeGestureRecognizer Direction="Right" Swiped="OnSwipedRight"/>
        </Grid.GestureRecognizers>

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,*">
            <Button Grid.Column="0" Text="&#x2193;" FontSize="24"
                    BackgroundColor="Transparent" TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    WidthRequest="36" HeightRequest="40" Padding="0"
                    HorizontalOptions="Start" VerticalOptions="Center"
                    Margin="15,4,0,0"
                    Clicked="ScrollToBottom_Clicked" />

            <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                <Button Text="&#x2039;" FontSize="32"
                        BackgroundColor="Transparent" TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        WidthRequest="40" HeightRequest="44" Padding="0"
                        Clicked="OnPreviousMonth" />
                <DatePicker x:Name="allCostsDatePicker"
                            Date="{Binding SelectedDate}"
                            Format="MM/yyyy"
                            FontSize="20"
                            HorizontalOptions="Center"
                            DateSelected="MyDatePicker_DateSelected"/>
                <Button Text="&#x203A;" FontSize="32"
                        BackgroundColor="Transparent" TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        WidthRequest="40" HeightRequest="44" Padding="0"
                        Clicked="OnNextMonth" />
            </HorizontalStackLayout>
        </Grid>

        <!-- Display costs in a list -->
        <CollectionView x:Name="costsCollection"
                        Grid.Row="1"
                        ItemsSource="{Binding Costs}"
                        Header="Date            Value         Category                  Description"
                        Margin="20,8,20,5"
                        SelectionMode="None">

            <CollectionView.HeaderTemplate>
                <DataTemplate>
                    <Grid Padding="5,0" ColumnSpacing="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="95" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Date" FontSize="17" FontAttributes="Bold" HorizontalTextAlignment="Start" />
                        <Label Grid.Column="1" Text="Value" FontSize="17" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="2" Text="Category" FontSize="17" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="3" Text="Description" FontSize="17" FontAttributes="Bold" HorizontalTextAlignment="Start" LineBreakMode="NoWrap" />
                    </Grid>
                </DataTemplate>
            </CollectionView.HeaderTemplate>

            <!-- Designate how the collection of items are laid out -->
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="1" />
            </CollectionView.ItemsLayout>

            <!-- Define the appearance of each item in the list -->
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CostModel">
                    <Grid Padding="5,5" ColumnSpacing="0" HeightRequest="39">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCostTapped" />
                        </Grid.GestureRecognizers>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="95" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="Transparent" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <Label Grid.Column="0" Text="{Binding FormattedDate, Mode=OneTime}" FontSize="17" VerticalOptions="Center" HorizontalTextAlignment="Start" InputTransparent="True"/>
                        <Label Grid.Column="1" Text="{Binding Value, StringFormat='{0:F2}', Mode=OneTime}" FontSize="17" VerticalOptions="Center" HorizontalTextAlignment="Center" InputTransparent="True"/>
                        <Label Grid.Column="2" Text="{Binding Category.Name, Mode=OneTime}" FontSize="17" VerticalOptions="Center" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" InputTransparent="True"/>
                        <Label Grid.Column="3" Text="{Binding Description, Mode=OneTime}" FontSize="17" VerticalOptions="Center" HorizontalTextAlignment="Start"
                               LineBreakMode="TailTruncation" InputTransparent="True"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <Label Grid.Row="2"
               x:Name="SumText"
               Text="{Binding Sum, StringFormat='Total sum: {0:F2}'}"
               FontSize="17" FontAttributes="Bold"
               TextColor="CadetBlue"
               Margin="20,0,20,5"
               HorizontalTextAlignment="Start" />

    </Grid>
</ContentPage>